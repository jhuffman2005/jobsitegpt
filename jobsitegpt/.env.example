# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Beta access code (used to gate registration)
VITE_BETA_CODE=JOBSITE2026

# Resend (used by /api/email and /api/smartlog-weekly-summary)
RESEND_API_KEY=re_...

# Supabase service role (used by serverless API routes that bypass RLS:
# /api/bid-submit, /api/smartlog, /api/smartlog-weekly-summary)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Vercel Cron auth secret (set the same value in Vercel dashboard → Settings →
# Cron). Used to gate /api/smartlog-weekly-summary against random callers.
CRON_SECRET=
