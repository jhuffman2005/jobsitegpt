{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/smartlog-weekly-summary", "schedule": "0 17 * * 5" }
  ]
}